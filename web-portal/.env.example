# Copy to .env and fill in real values (ask the backend lead for local keys).

# Supabase Postgres — pooled connection (port 6543) for the app runtime
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) — only used for prisma db push / migrations
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Google OAuth (NextAuth)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# NextAuth
NEXTAUTH_SECRET="generate-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Optional: Gemini key for the resume "improve text" feature
GEMINI_API_KEY=""
