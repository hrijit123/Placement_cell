generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum Role {
  STUDENT
  TEACHER
  RECRUITER
  ADMIN
}

enum VerificationStatus {
  SELF_REPORTED
  VERIFIED
  REJECTED
}

enum CareerRecordType {
  INTERVIEW
  PLACEMENT
}

enum InterviewOutcome {
  APPLIED
  SCHEDULED
  ATTENDED
  NO_SHOW
  OFFER_EXTENDED
  OFFER_ACCEPTED
  OFFER_REJECTED_BY_STUDENT
  REJECTED_BY_COMPANY
}



enum PlacementStatus {
  WORKING
  RESIGNED
  TERMINATED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

model User {
  id            String    @id @default(uuid())
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  // Removed password field as per security audit (OAuth exclusively used)
  role          Role      @default(STUDENT)
  status        UserStatus @default(ACTIVE)
  name          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NextAuth Relations
  accounts      Account[]
  sessions      Session[]

  // Core Relations (onDelete Restrict to preserve NGO records)
  profile          Profile?
  jobsPosted       Job[]              @relation("RecruiterJobs")
  attendance       Attendance[]       @relation("StudentAttendance")
  
  // Cohorts managed by a teacher
  cohortsLed       Cohort[]           @relation("TeacherCohorts")
  
  // Audit & Notifications
  accessLogs       AccessLog[]        @relation("UserAccessLogs")
  notifications    Notification[]     @relation("UserNotifications")
  auditLogs        RecordAuditLog[]   @relation("UserAuditLogs")
}

model Profile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  // NGO Universal ID
  studentId      String? @unique

  // General Details
  headline       String?
  address        String?
  languages      String? // comma separated
  hobbies        String?
  vocation       String? // Vocational interests/training
  disabilityInfo String? // Accommodations/Specifics for recruiters

  // Professional Background
  skills         String? // Stored as comma separated or JSON
  experience     String? // JSON or text
  education      String? // JSON containing { value, status: VerificationStatus }
  courseworks    String? // JSON or text
  internships    String? // JSON or text
  certifications String? // JSON array of certs
  transcripts    String? // JSON array of file URLs and term data
  
  // Job Preferences
  expectedSalary String?
  availability   String? // e.g. Full-time, Immediate

  resumePdfUrl   String?

  // Assigned Cohorts
  cohorts        Cohort[] @relation("StudentCohorts")

  // Relations
  careerTrack    CareerRecord[]
  notifications  Notification[]
  auditLogs      RecordAuditLog[]
}

model Cohort {
  id          String    @id @default(uuid())
  name        String
  description String?
  
  teacherId   String
  teacher     User      @relation("TeacherCohorts", fields: [teacherId], references: [id], onDelete: Restrict)
  
  students    Profile[] @relation("StudentCohorts")
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AccessLog {
  id              String   @id @default(uuid())
  actorId         String
  actor           User     @relation("UserAccessLogs", fields: [actorId], references: [id], onDelete: Restrict)
  
  targetStudentId String
  isOutOfCohort   Boolean  @default(false)
  reason          String?
  timestamp       DateTime @default(now())
}

model RecordAuditLog {
  id          String   @id @default(uuid())
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id])
  actorId     String   // The User who made the change
  actor       User     @relation("UserAuditLogs", fields: [actorId], references: [id], onDelete: Restrict)
  
  action      String   // "UPDATE", "CREATE", "VERIFY"
  field       String   // The specific field changed (e.g. "salary", "transcripts")
  oldValue    String?  @db.Text
  newValue    String?  @db.Text
  
  timestamp   DateTime @default(now())
}

model Notification {
  id          String   @id @default(uuid())
  recipientId String   // User ID
  recipient   User     @relation("UserNotifications", fields: [recipientId], references: [id], onDelete: Cascade)
  profileId   String?  // The student profile this relates to
  profile     Profile? @relation(fields: [profileId], references: [id])
  message     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Job {
  id          String   @id @default(uuid())
  title       String
  description String
  company     String
  location    String
  recruiterId String
  recruiter   User     @relation("RecruiterJobs", fields: [recruiterId], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isActive    Boolean  @default(true)
}

model CareerRecord {
  id              String   @id @default(uuid())
  profileId       String
  profile         Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  
  recordType      CareerRecordType
  
  // Common Fields
  company         String
  role            String
  verification    VerificationStatus @default(SELF_REPORTED)
  
  // Interview Specific
  interviewStatus InterviewOutcome?
  
  // Placement Specific
  placementStatus PlacementStatus?
  salary          Float?
  startDate       DateTime?
  endDate         DateTime?
  nextMove        String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Attendance {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation("StudentAttendance", fields: [userId], references: [id], onDelete: Restrict)
  
  date        DateTime
  status      AttendanceStatus @default(PRESENT)
  classOrEvent String? // Optional descriptor of what they attended
  
  createdAt   DateTime @default(now())
}

model Account {
  id                 String  @id @default(uuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
